# Root env template (do not put secrets here).
#
# apps/web (Next.js + Clerk + Convex)
#   - Put app-specific values in apps/web/.env.local
#   - `pnpm -C apps/web convex dev` will typically write CONVEX_DEPLOYMENT and NEXT_PUBLIC_CONVEX_URL
#     into apps/web/.env.local

# Clerk (apps/web)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk issuer / Frontend API URL for Convex auth config
CLERK_FRONTEND_API_URL=

# Convex dev deployment name (written by Convex CLI)
CONVEX_DEPLOYMENT=

# Convex deployment URL used by the Next.js client
NEXT_PUBLIC_CONVEX_URL=

# services/mortgage-data-engine (Cloudflare Worker)
#   - Local dev: services/mortgage-data-engine/.dev.vars (see .dev.vars.example)
#   - Production: use `wrangler secret put ...`
