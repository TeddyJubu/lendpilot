# apps/web local env template.
# The Convex CLI usually writes these automatically when you run `pnpm convex:dev`.

# Clerk (required for Phase 0.3 auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk issuer / Frontend API URL used by Convex auth.config.ts
# Example (development): https://verb-noun-00.clerk.accounts.dev
CLERK_FRONTEND_API_URL=

CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
