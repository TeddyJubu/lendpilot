{
  "name": "mortgage-data-engine",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute MORTGAGE_DB --file=./src/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute MORTGAGE_DB --local --file=./src/db/schema.sql",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^0.0.14",
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240614.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0",
    "wrangler": "^3.60.0"
  }
}
