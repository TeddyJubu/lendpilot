# ─── Firecrawl (required) ───
FIRECRAWL_API_KEY=fc-your-key-here

# ─── LLM Provider — pick one ───
MODEL_PROVIDER=anthropic
MODEL_ID=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Alternatively: OpenAI
# MODEL_PROVIDER=openai
# MODEL_ID=gpt-4o-mini
# OPENAI_API_KEY=sk-your-key-here

# ─── Auth (shared secret — Worker uses this as Bearer token) ───
LENDPILOT_AGENT_API_KEY=change-me-in-production

# ─── Mortgage Data Engine (where results are posted back) ───
LENDPILOT_WORKER_URL=https://mortgage-data-engine.workers.dev
LENDPILOT_WORKER_API_KEY=your-worker-admin-api-key

# ─── Server ───
PORT=3000
LOG=true
